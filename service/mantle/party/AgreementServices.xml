<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <service verb="create" noun="AgreementContent">
        <in-parameters>
            <auto-parameters entity-name="mantle.party.agreement.AgreementContent" include="nonpk">
                <exclude field-name="contentLocation"/></auto-parameters>
            <parameter name="agreementId" required="true"/>
            <parameter name="contentFile" type="org.apache.commons.fileupload.FileItem"/>
        </in-parameters>
        <out-parameters><parameter name="agreementContentId"/></out-parameters>
        <actions>
            <service-call name="create#mantle.party.agreement.AgreementContent" in-map="context" out-map="context"/>
            <if condition="contentFile != null &amp;&amp; contentFile.size &gt; 0">
                <service-call name="mantle.party.AgreementServices.save#AgreementContentFile" in-map="context"/></if>
        </actions>
    </service>
    <service verb="update" noun="AgreementContent">
        <in-parameters>
            <parameter name="agreementContentId" required="true"/>
            <auto-parameters entity-name="mantle.party.agreement.AgreementContent" include="nonpk">
                <exclude field-name="contentLocation"/></auto-parameters>
            <parameter name="contentFile" type="org.apache.commons.fileupload.FileItem"/>
        </in-parameters>
        <actions>
            <if condition="contentFile != null &amp;&amp; contentFile.size &gt; 0">
                <entity-find-one entity-name="mantle.party.agreement.AgreementContent" value-field="agreementContent"/>
                <service-call name="mantle.party.AgreementServices.save#AgreementContentFile" out-map="context"
                        in-map="context + [agreementId:agreementContent.agreementId, saveContentLocation:false]"/>
            </if>
            <service-call name="update#mantle.party.agreement.AgreementContent" in-map="context"/>
        </actions>
    </service>
    <service verb="save" noun="AgreementContentFile">
        <in-parameters>
            <parameter name="agreementContentId" required="true"/>
            <parameter name="agreementId" required="true"/>
            <parameter name="contentFile" type="org.apache.commons.fileupload.FileItem" required="true"/>
            <parameter name="saveContentLocation" type="Boolean" default="true"/>
        </in-parameters>
        <out-parameters><parameter name="contentLocation"/></out-parameters>
        <actions>
            <set field="filename" from="contentFile.getName()"/>
            <if condition="org.moqui.resource.ResourceReference.isTextFilename(filename)"><then>
                <set field="contentRoot" from="ec.user.getPreference('mantle.content.root') ?: 'dbresource://mantle/content'"/>
            </then><else>
                <set field="contentRoot" from="ec.user.getPreference('mantle.content.large.root') ?: 'dbresource://mantle/content'"/>
            </else></if>
            <set field="contentLocation" value="${contentRoot}/agreement/${agreementId}/content_${agreementContentId}/${filename}"/>

            <set field="docRr" from="ec.resource.getLocationReference(contentLocation)"/>
            <script>
                fileStream = contentFile.getInputStream()
                try { docRr.putStream(fileStream) } finally { fileStream.close() }
            </script>

            <if condition="saveContentLocation"><service-call name="update#mantle.party.agreement.AgreementContent"
                    in-map="[agreementContentId:agreementContentId, contentLocation:contentLocation]"/></if>
        </actions>
    </service>

    <service verb="find" noun="AgreementList">
        <description>Dangerous to expose directly to an endpoint of non ADMIN permission's user</description>
        <in-parameters>
            <parameter name="partyId" required="true" default="ec.user.userAccount?.partyId"><description>Assumed to be logged in and trusted to make query with parameters</description></parameter>
<!--            <parameter name="linkBase"><description>Send user to this link with agreementId filled in like https://yourserver.com/content. Will have ?agreementId=${agreementId} with the actual agreementId appended to the end</description></parameter>-->

            <parameter name="agreementTypeEnumIdList" type="List"><description>(optional) List of different agreementTypeEnumId's that are allowed</description></parameter>
            <parameter name="organizationPartyId"><description>(optional) If set will only find template agreements for this organizationPartyId</description></parameter>
            <parameter name="organizationRoleTypeId"><description>(optional) If set will only find template agreements with this organizationRoleTypeId</description></parameter>
        </in-parameters>
        <out-parameters>
            <parameter name="agreementList" type="List"/>
            <parameter name="needsSignature" type="Boolean"/>
        </out-parameters>
        <actions>
            <if condition="!agreementTypeEnumIdList"><set field="agreementTypeEnumIdList" from="[]"/></if>
            <set field="agreementTypeEnumIdList" from="agreementTypeEnumIdList.findAll{ it != null &amp;&amp; it != '' }"/>
            <entity-find entity-name="mantle.party.agreement.Agreement" list="agreementTemplateList">
                <econdition field-name="isTemplate" value="Y"/>

                <econdition field-name="agreementTypeEnumId" operator="in" from="agreementTypeEnumIdList" ignore="agreementTypeEnumIdList.size() == 0"/>
                <econdition field-name="organizationPartyId" from="organizationPartyId" ignore="!organizationPartyId"/>
                <econdition field-name="organizationRoleTypeId" from="organizationRoleTypeId" ignore="!organizationRoleTypeId"/>
                <date-filter/>

                <order-by field-name="-agreementDate,-fromDate"/>
            </entity-find>
            <if condition="agreementTemplateList.size() == 0">
                <return error="true" message="No agreements found"/>
            </if>
<!--            <log level="warn" message="AgreementList service called with partyId=${partyId}, agreementTypeEnumIdList=${agreementTypeEnumIdList}, organizationPartyId=${organizationPartyId}, organizationRoleTypeId=${organizationRoleTypeId}, agreementTemplateList.size=${agreementTemplateList.size()} list=${agreementTemplateList} ids=${agreementTemplateList*.agreementId}"/>-->

            <entity-find entity-name="mantle.party.agreement.Agreement" list="agreementSignedList">
                <econdition field-name="otherPartyId" from="partyId"/>
                <econdition field-name="templateAgreementId" operator="in" from="agreementTemplateList*.agreementId"/>
                <econdition field-name="isTemplate" value="N" or-null="true"/>

                <econdition field-name="agreementTypeEnumId" operator="in" from="agreementTypeEnumIdList" ignore="agreementTypeEnumIdList.size() == 0"/>
                <econdition field-name="organizationPartyId" from="organizationPartyId" ignore="!organizationPartyId"/>
                <econdition field-name="organizationRoleTypeId" from="organizationRoleTypeId" ignore="!organizationRoleTypeId"/>
                <date-filter/>
            </entity-find>

<!--            <log level="warn" message="AgreementList service found ${agreementSignedList.size()} signed agreements ${agreementSignedList}"/>-->

            <set field="agreementTemplateSignedIdList" from="agreementSignedList*.templateAgreementId"/>
            <set field="agreementList" from="[]"/>
            <iterate list="agreementTemplateList" entry="agreementTemplate">
                <set field="signedByUser" from="false"/>
                <set field="agreementDate" from="null"/>
                <set field="agreementTemplateSignedIdListSize" from="agreementTemplateSignedIdList.find{ it == agreementTemplate.agreementId }?.size()?:0"/>
                <if condition="agreementTemplateSignedIdListSize &gt; 0">
                    <set field="signedByUser" from="true"/>
                </if>

                <set field="agreementListSize" from="agreementList.find{ it.agreementId == agreementTemplate.agreementId }?.size()?:0"/>
                <if condition="agreementListSize == 0"><then>
                    <if condition="!agreementTemplate.description">
<!--                        <log level="warn" message="Agreement ${agreementTemplate.agreementId} has no description and is being set to Agreement"/>-->
                        <set field="agreementTemplate.description" value="Agreement"/>
                    </if>
                    <set field="agreementList" from="agreementList + [signedByUser:signedByUser,agreementId:agreementTemplate.agreementId,
                        description:agreementTemplate.description]"/>
                </then><else>
                    <log level="warn" message="Agreement ${agreementTemplate.agreementId} already in list"/>
                </else></if>
            </iterate>
<!--            <log level="warn" message="AgreementList service returning agreementList.size=${agreementList.size()} list=${agreementList}"/>-->
            <set field="agreementListSignedCount" from="agreementList.find{ it.signedByUser == false }?.size()?:0"/>
            <set field="needsSignature" from="agreementListSignedCount &gt; 0"/>

<!--            <log level="warn" message="AgreementList service returning agreementList.size=${agreementList.size()} list=${agreementList}"/>-->
        </actions>
    </service>
    <service verb="sign" noun="AgreementList">
        <in-parameters>
            <parameter name="partyId" required="true" default="ec.user.userAccount?.partyId"><description>Assumed to be logged in and trusted to make query with parameters</description></parameter>
            <parameter name="agreementList" required="true" type="List">
                <parameter name="signedByUser" type="Boolean"/>
                <parameter name="agreementId"/>
            </parameter>
            <parameter name="agreementDate" type="Timestamp"/>

            <parameter name="agreementTypeEnumIdList" type="List"><description>(optional) List of different agreementTypeEnumId's that are allowed</description></parameter>
            <parameter name="organizationPartyId"><description>(optional) If set will only find template agreements for this organizationPartyId</description></parameter>
            <parameter name="organizationRoleTypeId"><description>(optional) If set will only find template agreements with this organizationRoleTypeId</description></parameter>
            
            <parameter name="otherRoleTypeId" default-value="CustomerEndUser"/>
        </in-parameters>
        <out-parameters>
            <parameter name="signedAgreementList" type="List"/>
        </out-parameters>
        <actions>
            <if condition="!agreementTypeEnumIdList"><set field="agreementTypeEnumIdList" from="[]"/></if>
            <set field="agreementTypeEnumIdList" from="agreementTypeEnumIdList.findAll{ it != null &amp;&amp; it != '' }"/>
            <entity-find entity-name="mantle.party.agreement.Agreement" list="agreementTemplateList">
                <econdition field-name="isTemplate" value="Y"/>

                <econdition field-name="agreementTypeEnumId" operator="in" from="agreementTypeEnumIdList" ignore="agreementTypeEnumIdList.size() == 0"/>
                <econdition field-name="organizationPartyId" from="organizationPartyId" ignore="!organizationPartyId"/>
                <econdition field-name="organizationRoleTypeId" from="organizationRoleTypeId" ignore="!organizationRoleTypeId"/>
                <date-filter/>

                <order-by field-name="-agreementDate,-fromDate"/>
            </entity-find>
            <if condition="agreementTemplateList.size() == 0">
                <return error="true" message="No agreements found"/>
            </if>

            <iterate list="agreementList" entry="agreement">
                <if condition="agreement.signedByUser == null">
                    <set field="agreement.signedByUser" from="false"/>
                </if>
                <if condition="agreement.signedByUser.getClass().getName() != 'java.lang.Boolean'">
                    <set field="agreement.signedByUser" from="agreement.signedByUser as Boolean"/>
                </if>
            </iterate>
            <set field="agreement" from="null"/>

            <set field="agreementsToSignList" from="agreementList.findAll{ it.signedByUser != null &amp;&amp; it.agreementId != null }"/>
<!--            <set field="agreementsToSignList" from="agreementsToSignList.findAll{ it.signedByUser != null &amp;&amp; it.signedByUser as Boolean == true }"/>-->

            <entity-find entity-name="mantle.party.agreement.Agreement" list="agreementTemplateList">
                <econdition field-name="agreementId" operator="in" from="agreementsToSignList*.agreementId"/>
                <econdition field-name="templateAgreementId" operator="in" from="agreementTemplateList*.agreementId"/>
                <econdition field-name="isTemplate" value="Y"/>

                <econdition field-name="agreementTypeEnumId" operator="in" from="agreementTypeEnumIdList" ignore="agreementTypeEnumIdList.size() == 0"/>
                <econdition field-name="organizationPartyId" from="organizationPartyId" ignore="!organizationPartyId"/>
                <econdition field-name="organizationRoleTypeId" from="organizationRoleTypeId" ignore="!organizationRoleTypeId"/>
                <date-filter/>

                <order-by field-name="-agreementDate,-fromDate"/>
            </entity-find>

            <set field="signedAgreementList" from="[]"/>
            <iterate list="agreementTemplateList" entry="newAgreement">
                <set field="templateAgreementId" from="newAgreement.agreementId"/>

                <set field="newAgreement.agreementId" from="null"/>
                <set field="newAgreement.agreementDate" from="agreementDate?:ec.user.nowTimestamp"/>
                <set field="newAgreement.fromDate" from="ec.user.nowTimestamp"/>
                <set field="newAgreement.thruDate" from="null"/>
                <entity-sequenced-id-primary value-field="newAgreement"/>

                <!-- set nonpk fields from context, if passed -->
<!--                <entity-set value-field="newAgreement" include="nonpk"/>-->
                <set field="newAgreement.isTemplate" value="N"/>
                <set field="newAgreement.templateAgreementId" from="templateAgreementId"/>
                <set field="newAgreement.otherPartyId" from="partyId"/>
                <set field="newAgreement.otherRoleTypeId" from="otherRoleTypeId"/>

                <entity-create value-field="newAgreement"/>

                <entity-find entity-name="mantle.party.agreement.AgreementContent" list="valueList">
                    <econdition field-name="agreementId" from="templateAgreementId"/>
                    <order-by field-name="-contentDate"/></entity-find>
                <iterate list="valueList" entry="value">
                    <set field="value.agreementContentId" from="null"/>
                    <set field="value.agreementId" from="newAgreement.agreementId"/>
                    <entity-sequenced-id-primary value-field="value"/>
                    <entity-set value-field="value" include="nonpk"/>
                    <entity-create value-field="value"/>
                </iterate>

                <set field="signedAgreementList" from="signedAgreementList + [agreementId:newAgreement.agreementId]"/>
            </iterate>
        </actions>
    </service>
    <service verb="get" noun="AgreementText">
        <in-parameters>
            <parameter name="agreementId" required="true"/>
            <parameter name="versionName"/>

            <parameter name="agreementTypeEnumIdList" type="List"><description>(optional) List of different agreementTypeEnumId's that are allowed</description></parameter>
            <parameter name="organizationPartyId"><description>(optional) If set will only find template agreements for this organizationPartyId</description></parameter>
            <parameter name="organizationRoleTypeId"><description>(optional) If set will only find template agreements with this organizationRoleTypeId</description></parameter>
        </in-parameters>
        <out-parameters>
            <parameter name="pageLocation"/>
            <parameter name="agreementText"/>
        </out-parameters>
        <actions>
            <if condition="!agreementTypeEnumIdList"><set field="agreementTypeEnumIdList" from="[]"/></if>
            <set field="agreementTypeEnumIdList" from="agreementTypeEnumIdList.findAll{ it != null &amp;&amp; it != '' }"/>
            <entity-find entity-name="mantle.party.agreement.Agreement" list="agreementTemplateList" limit="1">
                <econdition field-name="agreementId"/>
                <econdition field-name="isTemplate" value="Y"/>

                <econdition field-name="agreementTypeEnumId" operator="in" from="agreementTypeEnumIdList" ignore="agreementTypeEnumIdList.size() == 0"/>
                <econdition field-name="organizationPartyId" from="organizationPartyId" ignore="!organizationPartyId"/>
                <econdition field-name="organizationRoleTypeId" from="organizationRoleTypeId" ignore="!organizationRoleTypeId"/>
                <date-filter/></entity-find>
            <if condition="agreementTemplateList.size() == 0 || !agreementTemplateList.getFirst().agreementId">
                <return error="true" message="Agreement not found"/>
            </if>

            <set field="agreementId" from="agreementTemplateList.getFirst().agreementId"/>
            <entity-find entity-name="mantle.party.agreement.AgreementContent" list="agreementList">
                <econdition field-name="agreementId"/>
                <econdition field-name="contentTypeEnumId" value="AcntDocument"/>
                <econdition field-name="contentLocation" operator="is-not-null"/>
                <order-by field-name="-contentDate"/></entity-find>
            <if condition="agreementList.size() == 0 || !agreementList.getFirst().contentLocation">
                <return error="true" message="Agreement not found"/>
            </if>

            <set field="pageLocation" from="agreementList.getFirst().contentLocation"/>
            <set field="agreementText" from="ec.resource.getLocationReference(pageLocation).getText()"/>
        </actions>
    </service>
</services>
