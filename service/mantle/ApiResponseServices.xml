<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd">

    <!-- ==================== Mantle USL统一REST API响应包装服务 ==================== -->

    <service verb="wrap" noun="MantleApiResponse" authenticate="false" allow-remote="false">
        <description>Mantle USL统一REST API响应格式包装服务</description>
        <in-parameters>
            <parameter name="data" type="Object" required="false">
                <description>Mantle业务数据对象</description>
            </parameter>
            <parameter name="success" type="Boolean" default="true">
                <description>操作是否成功</description>
            </parameter>
            <parameter name="code" type="Integer" default="200">
                <description>HTTP状态码</description>
            </parameter>
            <parameter name="message" type="String" default="Mantle操作成功">
                <description>提示消息</description>
            </parameter>
            <parameter name="errors" type="List" required="false">
                <description>错误信息列表</description>
            </parameter>
            <parameter name="entityName" type="String" required="false">
                <description>相关实体名称</description>
            </parameter>
            <parameter name="operation" type="String" required="false">
                <description>执行的操作类型</description>
            </parameter>
            <parameter name="businessDomain" type="String" required="false">
                <description>业务域（parties/orders/products等）</description>
            </parameter>
        </in-parameters>
        <out-parameters>
            <parameter name="response" type="Map">
                <description>标准化的Mantle REST响应</description>
            </parameter>
        </out-parameters>
        <actions>
            <script><![CDATA[
                import groovy.json.JsonOutput
                import java.util.UUID

                // 生成请求ID
                String actualRequestId = "mantle_req_${UUID.randomUUID().toString().substring(0, 8)}"

                // 构建标准响应结构
                Map standardResponse = [:]
                standardResponse.success = success ?: true
                standardResponse.code = code ?: 200
                standardResponse.message = message ?: (success ? "Mantle操作成功" : "Mantle操作失败")

                // Mantle业务数据
                if (data != null) {
                    standardResponse.data = data
                }

                // 错误信息处理
                if (errors && !errors.isEmpty()) {
                    standardResponse.errors = errors
                    standardResponse.success = false
                    if (!code || code == 200) {
                        standardResponse.code = 400
                    }
                }

                // Mantle专用元数据
                Map meta = [:]
                meta.timestamp = ec.user.nowTimestamp.time
                meta.requestId = actualRequestId
                meta.version = "1.2.0"
                meta.component = "Mantle-USL"
                meta.server = "Moqui-Mantle-${ec.web.request.serverName}"

                // Mantle特有信息
                if (entityName) meta.entityName = entityName
                if (operation) meta.operation = operation
                if (businessDomain) meta.businessDomain = businessDomain
                meta.framework = "Moqui-Mantle"

                standardResponse.meta = meta

                response = standardResponse

                // 错误时设置HTTP状态码
                if (!success || (errors && !errors.isEmpty())) {
                    ec.web.response.setStatus(code ?: 400)
                }
            ]]></script>
        </actions>
    </service>

    <service verb="wrap" noun="MantleEntityResponse" authenticate="false" allow-remote="false">
        <description>Mantle实体操作响应包装</description>
        <in-parameters>
            <parameter name="entityData" type="Object" required="true">
                <description>实体数据</description>
            </parameter>
            <parameter name="entityName" type="String" required="true">
                <description>实体名称</description>
            </parameter>
            <parameter name="operation" type="String" required="true">
                <description>操作类型（create/read/update/delete/list）</description>
            </parameter>
            <parameter name="businessDomain" type="String" required="false">
                <description>业务域</description>
            </parameter>
        </in-parameters>
        <out-parameters>
            <parameter name="response" type="Map">
                <description>标准化的实体响应</description>
            </parameter>
        </out-parameters>
        <actions>
            <script><![CDATA[
                String operationMessage = ""
                switch (operation?.toLowerCase()) {
                    case "create": operationMessage = "创建成功"; break
                    case "read":
                    case "one": operationMessage = "查询成功"; break
                    case "update": operationMessage = "更新成功"; break
                    case "delete": operationMessage = "删除成功"; break
                    case "list": operationMessage = "列表查询成功"; break
                    default: operationMessage = "操作成功"
                }

                // 调用统一包装服务
                Map wrapResult = ec.service.sync().name("mantle.ApiResponseServices.wrap#MantleApiResponse")
                    .parameters([
                        data: entityData,
                        success: true,
                        code: 200,
                        message: operationMessage,
                        entityName: entityName,
                        operation: operation,
                        businessDomain: businessDomain
                    ]).call()

                response = wrapResult.response
            ]]></script>
        </actions>
    </service>

    <service verb="wrap" noun="MantleListResponse" authenticate="false" allow-remote="false">
        <description>Mantle列表响应包装</description>
        <in-parameters>
            <parameter name="items" type="List" required="true">
                <description>实体列表</description>
            </parameter>
            <parameter name="total" type="Long" required="false">
                <description>总数量</description>
            </parameter>
            <parameter name="page" type="Integer" default="1">
                <description>当前页</description>
            </parameter>
            <parameter name="limit" type="Integer" default="20">
                <description>每页大小</description>
            </parameter>
            <parameter name="entityName" type="String" required="false">
                <description>实体名称</description>
            </parameter>
            <parameter name="businessDomain" type="String" required="false">
                <description>业务域</description>
            </parameter>
        </in-parameters>
        <out-parameters>
            <parameter name="response" type="Map">
                <description>标准化的列表响应</description>
            </parameter>
        </out-parameters>
        <actions>
            <script><![CDATA[
                // 计算分页信息
                Long actualTotal = total ?: (items ? items.size() : 0)
                Integer pageCount = limit > 0 ? Math.ceil(actualTotal / limit) as Integer : 1

                // 构建列表数据结构
                Map listData = [:]
                listData.items = items ?: []
                listData.count = items ? items.size() : 0

                // 调用统一包装服务
                Map wrapResult = ec.service.sync().name("mantle.ApiResponseServices.wrap#MantleApiResponse")
                    .parameters([
                        data: listData,
                        success: true,
                        code: 200,
                        message: "列表查询成功",
                        entityName: entityName,
                        operation: "list",
                        businessDomain: businessDomain
                    ]).call()

                // 添加分页信息到meta
                wrapResult.response.meta.pagination = [
                    total: actualTotal,
                    page: page,
                    limit: limit,
                    pageCount: pageCount
                ]

                response = wrapResult.response
            ]]></script>
        </actions>
    </service>

    <service verb="wrap" noun="MantleErrorResponse" authenticate="false" allow-remote="false">
        <description>Mantle错误响应包装</description>
        <in-parameters>
            <parameter name="errorMessage" type="String" required="true">
                <description>错误消息</description>
            </parameter>
            <parameter name="errorCode" type="Integer" default="500">
                <description>错误代码</description>
            </parameter>
            <parameter name="entityName" type="String" required="false">
                <description>相关实体名称</description>
            </parameter>
            <parameter name="operation" type="String" required="false">
                <description>失败的操作</description>
            </parameter>
            <parameter name="validationErrors" type="Map" required="false">
                <description>字段验证错误</description>
            </parameter>
        </in-parameters>
        <out-parameters>
            <parameter name="response" type="Map">
                <description>标准化的Mantle错误响应</description>
            </parameter>
        </out-parameters>
        <actions>
            <script><![CDATA[
                // 构建错误信息列表
                List errorList = []
                errorList.add(errorMessage)

                Map errorData = null
                if (validationErrors) {
                    errorData = [validation: validationErrors]
                }

                // 调用统一包装服务
                Map wrapResult = ec.service.sync().name("mantle.ApiResponseServices.wrap#MantleApiResponse")
                    .parameters([
                        data: errorData,
                        success: false,
                        code: errorCode,
                        message: errorMessage,
                        errors: errorList,
                        entityName: entityName,
                        operation: operation
                    ]).call()

                response = wrapResult.response
            ]]></script>
        </actions>
    </service>

    <service verb="wrap" noun="MantleBusinessResponse" authenticate="false" allow-remote="false">
        <description>Mantle业务操作响应包装（订单、支付、发货等）</description>
        <in-parameters>
            <parameter name="businessData" type="Object" required="true">
                <description>业务数据</description>
            </parameter>
            <parameter name="businessDomain" type="String" required="true">
                <description>业务域（orders/payments/shipments等）</description>
            </parameter>
            <parameter name="operation" type="String" required="true">
                <description>业务操作</description>
            </parameter>
            <parameter name="businessId" type="String" required="false">
                <description>业务单据ID</description>
            </parameter>
        </in-parameters>
        <out-parameters>
            <parameter name="response" type="Map">
                <description>标准化的业务响应</description>
            </parameter>
        </out-parameters>
        <actions>
            <script><![CDATA[
                // 调用统一包装服务
                Map wrapResult = ec.service.sync().name("mantle.ApiResponseServices.wrap#MantleApiResponse")
                    .parameters([
                        data: businessData,
                        success: true,
                        code: 200,
                        message: "业务操作成功",
                        operation: operation,
                        businessDomain: businessDomain
                    ]).call()

                // 添加业务特有信息
                if (businessId) {
                    wrapResult.response.meta.businessId = businessId
                }
                wrapResult.response.meta.responseType = "business"

                response = wrapResult.response
            ]]></script>
        </actions>
    </service>

</services>